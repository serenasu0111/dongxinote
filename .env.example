# 环境变量配置
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dongxi_notes

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# 豆包 AI API (替换为实际的 API Key)
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 阿里云 OCR (替换为实际的 API Key)
ALIYUN_OCR_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_OCR_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
